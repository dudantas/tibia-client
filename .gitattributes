.gitattributes text eol=lf
.gitignore text eol=lf
*.json text eol=lf
*.sha256 text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Official payloads are validated by assets.json hashes.
# Preserve their exact bytes, including CRLF when the official file uses it.
assets/** binary -eol
sounds/** binary -eol

*.lzma binary
*.ogg binary
*.dat binary
*.bmp binary
*.png binary
*.dll binary
*.exe binary
*.pak binary
*.rar binary
